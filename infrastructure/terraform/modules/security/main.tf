# ACM Certificate
resource "aws_acm_certificate" "main" {
  domain_name       = "riskoptimizer.com"
  validation_method = "DNS"

  subject_alternative_names = [
    "*.riskoptimizer.com",
    "api.riskoptimizer.com",
    "app.riskoptimizer.com"
  ]

  lifecycle {
    create_before_destroy = true
  }

  tags = merge(var.tags, {
    Name        = "${var.name_prefix}-certificate"
    Environment = var.environment
  })
}

# GuardDuty
resource "aws_guardduty_detector" "main" {
  count  = var.enable_guardduty ? 1 : 0
  enable = true

  datasources {
    s3_logs {
      enable = true
    }
    kubernetes {
      audit_logs {
        enable = true
      }
    }
    malware_protection {
      scan_ec2_instance_with_findings {
        ebs_volumes {
          enable = true
        }
      }
    }
  }

  tags = merge(var.tags, {
    Name        = "${var.name_prefix}-guardduty"
    Environment = var.environment
  })
}
