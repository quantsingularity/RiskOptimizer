# RiskOptimizer Environment Variables
# Copy to .env and fill in values - NEVER commit .env to version control

# Application (Flask backend)
FLASK_ENV=production
IMAGE_TAG=latest
LOG_LEVEL=INFO

# Database
DB_NAME=riskoptimizerdb
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Secrets (read by the Flask app: SECRET_KEY and JWT_SECRET_KEY)
SECRET_KEY=CHANGE_ME_MINIMUM_32_CHAR_SECRET_HERE
JWT_SECRET_KEY=CHANGE_ME_MINIMUM_32_CHAR_SECRET_HERE

# CORS: comma-separated origins allowed to call the API (the web app dev origin)
CORS_ORIGINS=http://localhost:3000

# Web frontend build-time API base (inlined by Vite at build time)
VITE_API_URL=/api

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD_HERE

# Data directory for volume mounts
DATA_DIR=./data
