# RiskOptimizer Environment Variables
# Copy to .env and fill in values - NEVER commit .env to version control

# Application
NODE_ENV=development
IMAGE_TAG=latest
LOG_LEVEL=info

# Database
DB_NAME=riskoptimizerdb
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Secrets
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHAR_SECRET_HERE
API_KEY=CHANGE_ME_API_KEY_HERE

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD_HERE

# Data directory for volume mounts
DATA_DIR=./data
